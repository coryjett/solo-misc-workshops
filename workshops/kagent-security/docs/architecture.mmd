graph LR
    subgraph IdP["Identity Provider"]
        KC["Keycloak<br/>OIDC<br/>group + role claims"]
        Users["admin (role=admin)<br/>writer (role=writer)<br/>reader (role=reader)"]
    end

    subgraph KE["kagent Enterprise"]
        UI["Solo Enterprise UI"]
        RBAC["RBAC<br/>Groups → Roles"]
        CTRL["Controller<br/>mints OBO JWT<br/>(propagates role)"]
        AP["AccessPolicy<br/>(created in UI)<br/>jwt.role == 'admin'"]
    end

    subgraph Mesh["Istio Ambient Mesh"]
        ZT["ztunnel<br/>L4 capture"]
        WP["Waypoint Gateway<br/>(in front of security-auditor)<br/>JWT validate + CEL allow/deny"]
    end

    subgraph Agents
        A2["k8s-explorer<br/>✅ all users<br/>🔧 kubectl tools"]
        A3["security-auditor<br/>🔒 admins only<br/>🔧 kubectl tools"]
    end

    KC -->|OIDC login| UI
    UI --> CTRL
    CTRL -->|OBO JWT<br/>iss=kagent.kagent<br/>role=admin| ZT
    ZT --> A2
    ZT --> WP
    WP -->|admin: 200| A3
    WP -->|reader: 403<br/>authorization failed| A3
    AP -.->|programs| WP

    style KC fill:#ffd8a8,stroke:#f59e0b
    style Users fill:#fff3bf,stroke:#f59e0b
    style UI fill:#a5d8ff,stroke:#4a9eed
    style RBAC fill:#a5d8ff,stroke:#4a9eed
    style CTRL fill:#a5d8ff,stroke:#4a9eed
    style AP fill:#d0bfff,stroke:#8b5cf6
    style ZT fill:#eebefa,stroke:#8b5cf6
    style WP fill:#d0bfff,stroke:#8b5cf6
    style A2 fill:#b2f2bb,stroke:#22c55e
    style A3 fill:#ffc9c9,stroke:#ef4444
